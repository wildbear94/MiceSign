{
  "exportFormatVersion": 1,
  "schemaVersion": 1,
  "name": "출장신청서",
  "description": "일정·동행자·예상 비용 계산을 포함합니다",
  "prefix": "TRP",
  "category": "general",
  "icon": "Plane",
  "schemaDefinition": {
    "version": 1,
    "fields": [
      { "id": "destination", "type": "text", "label": "출장지", "required": true },
      { "id": "startDate", "type": "date", "label": "출발일", "required": true },
      { "id": "endDate", "type": "date", "label": "복귀일", "required": true },
      { "id": "companions", "type": "textarea", "label": "동행자", "required": false },
      {
        "id": "costs",
        "type": "table",
        "label": "예상 비용",
        "required": true,
        "config": {
          "columns": [
            { "id": "category", "type": "text", "label": "항목", "required": true },
            { "id": "amount", "type": "number", "label": "금액", "required": true }
          ],
          "minRows": 1
        }
      },
      {
        "id": "totalCost",
        "type": "number",
        "label": "총 예상 비용",
        "required": false,
        "config": { "unit": "원" }
      },
      { "id": "purpose", "type": "textarea", "label": "출장 목적", "required": true }
    ],
    "conditionalRules": [],
    "calculationRules": [
      { "targetFieldId": "totalCost", "formula": "SUM(costs.amount)", "dependsOn": ["costs"] }
    ]
  }
}
