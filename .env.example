# MiceSign Environment Variables
# See backend/.env.example for backend-specific variables
# See frontend/.env (if needed) for frontend-specific variables
#
# Quick start:
#   1. Copy backend/.env.example to backend/.env
#   2. Start MariaDB (docker run -d --name micesign-db -e MYSQL_ROOT_PASSWORD=root -e MYSQL_DATABASE=micesign -e MYSQL_USER=micesign -e MYSQL_PASSWORD=micesign -p 3306:3306 mariadb:10.11)
#   3. cd backend && ./gradlew bootRun --args='--spring.profiles.active=dev'
#   4. cd frontend && npm run dev
#   5. Open http://localhost:5173
