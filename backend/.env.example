# MiceSign Backend Environment Variables
# Copy to .env and fill in values

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=micesign
DB_USER=micesign
DB_PASS=micesign

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Default SUPER_ADMIN credentials (temporary - change after first login)
# Email: admin@micesign.com
